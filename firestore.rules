rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function myUserExists() {
      return signedIn() && exists(myUserPath());
    }

    function myUser() {
      return get(myUserPath()).data;
    }

    function myRole() {
      return myUserExists() ? myUser().role : null;
    }

    function myReviewerType() {
      return myUserExists() &&
             myUser().reviewerType is string
        ? myUser().reviewerType
        : "";
    }

    function requestedCreatedByReviewerType() {
      return request.resource.data.createdByReviewerType is string
        ? request.resource.data.createdByReviewerType
        : "";
    }

    function roleMatches(primary, alternate) {
      return myRole() == primary || myRole() == alternate;
    }

    function isAdmin() {
      return myRole() == "Admin";
    }

    function isManager() {
      return myRole() == "Manager";
    }

    function isLeadInspector() {
      return myRole() == "Lead Inspector";
    }

    function isExternalReviewer() {
      return roleMatches("External_Reviewer", "External Reviewer") ||
             (
               myUserExists() &&
               myReviewerType() != ""
             );
    }

    function isInspector() {
      return myRole() == "Inspector";
    }

    function isReviewerTier() {
      return isLeadInspector() || isExternalReviewer();
    }

    function isManagerOrAbove() {
      return isManager() || isAdmin();
    }

    function isLeadOrAbove() {
      return isReviewerTier() || isManagerOrAbove();
    }

    function isExternalReviewerManagedRole(role) {
      return role == "External_Reviewer" ||
             role == "External Reviewer" ||
             role == "Inspector" ||
             role == "Lead Inspector";
    }

    function isOwnedExternalReviewerUserCreate() {
      return isExternalReviewer() &&
             isExternalReviewerManagedRole(request.resource.data.role) &&
             request.resource.data.createdByUserId == request.auth.uid &&
             requestedCreatedByReviewerType() == myReviewerType();
    }

    function isOwnedExternalReviewerUserUpdate() {
      return isExternalReviewer() &&
             isExternalReviewerManagedRole(resource.data.role) &&
             resource.data.createdByUserId == request.auth.uid &&
             isExternalReviewerManagedRole(request.resource.data.role) &&
             request.resource.data.createdByUserId == resource.data.createdByUserId &&
             requestedCreatedByReviewerType() == myReviewerType();
    }

    function projectAssignedToMe(data) {
      return signedIn() && (
        data.inspectorId == request.auth.uid ||
        data.supervisorId == request.auth.uid ||
        data.externalReviewerId == request.auth.uid ||
        data.externalReviewerId2 == request.auth.uid ||
        data.externalReviewerId3 == request.auth.uid ||
        data.externalReviewerId4 == request.auth.uid ||
        data.externalReviewerId5 == request.auth.uid ||
        data.externalReviewerId6 == request.auth.uid ||
        data.managerId == request.auth.uid
      );
    }

    function projectMatchesMyClient(data) {
      return signedIn() &&
             isExternalReviewer() &&
             (
               (
                 myUser().clientId is string &&
                 data.clientId is string &&
                 myUser().clientId == data.clientId
               ) ||
               (
                 myUser().clientName is string &&
                 (
                   data.clientName is string ||
                   data.client is string
                 ) &&
                 myUser().clientName == (
                   data.clientName is string ? data.clientName : data.client
                 )
               )
             );
    }

    function canReadProject(data) {
      return isAdmin() ||
             isManager() ||
             isReviewerTier() ||
             projectAssignedToMe(data) ||
             projectMatchesMyClient(data);
    }

    function canUpdateProject(data) {
      return isAdmin() ||
             data.inspectorId == request.auth.uid ||
             data.supervisorId == request.auth.uid ||
             data.externalReviewerId == request.auth.uid ||
             data.externalReviewerId2 == request.auth.uid ||
             data.externalReviewerId3 == request.auth.uid ||
             data.externalReviewerId4 == request.auth.uid ||
             data.externalReviewerId5 == request.auth.uid ||
             data.externalReviewerId6 == request.auth.uid ||
             data.managerId == request.auth.uid;
    }

    function isOwnLog() {
      return signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.userEmail == request.auth.token.email
      );
    }

    function isCreatingOwnLog() {
      return signedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.userEmail == request.auth.token.email
      );
    }

    function projectDocById(projectDocId) {
      return get(/databases/$(database)/documents/projects/$(projectDocId));
    }

    function projectDocExists(projectDocId) {
      return projectDocId is string &&
             exists(/databases/$(database)/documents/projects/$(projectDocId));
    }

    function threadHasProjectDoc(threadData) {
      return threadData.projectDocId is string &&
             projectDocExists(threadData.projectDocId);
    }

    function canAccessThread(threadData) {
      return signedIn() && (
        isAdmin() ||
        (
          threadHasProjectDoc(threadData) &&
          projectAssignedToMe(projectDocById(threadData.projectDocId).data)
        ) ||
        (
          threadData.participantIds is list &&
          request.auth.uid in threadData.participantIds
        )
      );
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        userId == request.auth.uid ||
        isLeadOrAbove()
      );

      allow create: if signedIn() && (
        userId == request.auth.uid ||
        isAdmin() ||
        isOwnedExternalReviewerUserCreate()
      );

      allow update: if signedIn() && (
        userId == request.auth.uid ||
        isAdmin() ||
        isOwnedExternalReviewerUserUpdate()
      );

      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if signedIn() && canReadProject(resource.data);

      allow create: if isAdmin();

      allow update: if signedIn() && canUpdateProject(resource.data);

      allow delete: if isManagerOrAbove();
    }

    match /project_chats/{threadId} {
      allow read: if canAccessThread(resource.data);

      allow create: if signedIn() && (
        isAdmin() ||
        (
          request.resource.data.projectDocId is string &&
          projectDocExists(request.resource.data.projectDocId) &&
          projectAssignedToMe(projectDocById(request.resource.data.projectDocId).data)
        )
      );

      allow update: if signedIn() && (
        isAdmin() ||
        canAccessThread(resource.data) ||
        (
          request.resource.data.projectDocId is string &&
          projectDocExists(request.resource.data.projectDocId) &&
          projectAssignedToMe(projectDocById(request.resource.data.projectDocId).data)
        )
      );

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if canAccessThread(
          get(/databases/$(database)/documents/project_chats/$(threadId)).data
        );

        allow create: if signedIn() && (
          isAdmin() ||
          (
            request.resource.data.projectDocId is string &&
            projectDocExists(request.resource.data.projectDocId) &&
            projectAssignedToMe(projectDocById(request.resource.data.projectDocId).data) &&
            request.resource.data.userId == request.auth.uid
          ) ||
          (
            get(/databases/$(database)/documents/project_chats/$(threadId)).exists() &&
            canAccessThread(
              get(/databases/$(database)/documents/project_chats/$(threadId)).data
            ) &&
            request.resource.data.userId == request.auth.uid
          )
        );

        allow update, delete: if isAdmin();
      }
    }

    match /external_feedback/{feedbackId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.externalReviewerId == request.auth.uid
      );

      allow create: if signedIn() && (
        isExternalReviewer() &&
        request.resource.data.externalReviewerId == request.auth.uid
      );

      allow update, delete: if isAdmin();
    }

    match /issue_logs/{issueId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.reportedById == request.auth.uid
      );

      allow create: if signedIn() &&
        request.resource.data.reportedById == request.auth.uid;

      allow update: if signedIn() && (
        isAdmin() ||
        resource.data.reportedById == request.auth.uid
      );

      allow delete: if isAdmin();
    }

    match /project_verification_reviews/{projectId}/reviewers/{uid} {
      allow read: if signedIn() && (
        isAdmin() ||
        (
          projectDocExists(projectId) &&
          canReadProject(projectDocById(projectId).data)
        )
      );

      allow create: if signedIn() &&
        request.auth.uid == uid &&
        isExternalReviewer() &&
        projectDocExists(projectId) &&
        projectAssignedToMe(projectDocById(projectId).data) &&
        request.resource.data.projectDocId == projectId &&
        request.resource.data.externalReviewerId == request.auth.uid;

      allow update: if signedIn() && (
        (
          request.auth.uid == uid &&
          isExternalReviewer() &&
          projectDocExists(projectId) &&
          projectAssignedToMe(projectDocById(projectId).data) &&
          request.resource.data.projectDocId == projectId &&
          request.resource.data.externalReviewerId == request.auth.uid
        ) ||
        (
          isManagerOrAbove() &&
          projectDocExists(projectId) &&
          canReadProject(projectDocById(projectId).data)
        )
      );

      allow delete: if isAdmin();
    }

    match /report_review_checklists/{docId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (
          resource.data.projectDocId is string &&
          projectDocExists(resource.data.projectDocId) &&
          canReadProject(projectDocById(resource.data.projectDocId).data)
        )
      );

      allow create: if signedIn() &&
        isExternalReviewer() &&
        request.resource.data.externalReviewerId == request.auth.uid &&
        request.resource.data.projectDocId is string &&
        projectDocExists(request.resource.data.projectDocId) &&
        projectAssignedToMe(projectDocById(request.resource.data.projectDocId).data);

      allow update: if signedIn() && (
        (
          isExternalReviewer() &&
          resource.data.externalReviewerId == request.auth.uid &&
          request.resource.data.externalReviewerId == request.auth.uid &&
          resource.data.projectDocId is string &&
          projectDocExists(resource.data.projectDocId) &&
          projectAssignedToMe(projectDocById(resource.data.projectDocId).data)
        ) ||
        (
          isManagerOrAbove() &&
          resource.data.projectDocId is string &&
          projectDocExists(resource.data.projectDocId) &&
          canReadProject(projectDocById(resource.data.projectDocId).data)
        )
      );

      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if signedIn() && (
        isAdmin() ||
        isManager() ||
        isOwnLog()
      );

      allow create: if signedIn() && (
        isAdmin() ||
        isManager() ||
        isReviewerTier() ||
        isCreatingOwnLog()
      );

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /locations/{locationId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /equipment/{equipmentId} {
      allow read: if isLeadOrAbove();
      allow create, update: if isManagerOrAbove() || isExternalReviewer();
      allow delete: if isManagerOrAbove();
    }

    match /inspection_schedules/{scheduleId} {
      allow read: if isAdmin() ||
                    isManager() ||
                    isLeadInspector() ||
                    (
                      isExternalReviewer() &&
                      resource.data.externalReviewerId == request.auth.uid
                    );
      allow create, update: if isManagerOrAbove() ||
                              (
                                isExternalReviewer() &&
                                request.resource.data.externalReviewerId == request.auth.uid
                              );
      allow delete: if isAdmin();
    }

    match /inspection_types/{typeId} {
      allow read: if isLeadOrAbove();
      allow create, update, delete: if isAdmin();
    }

    match /inspection_type/{typeId} {
      allow read: if isLeadOrAbove();
      allow create, update, delete: if isAdmin();
    }

    match /inspections/{inspectionId} {
      allow read: if isLeadOrAbove();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /companyprofile/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
